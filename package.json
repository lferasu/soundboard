{
  "name": "super-soundboard-native",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "npx expo start",
    "android": "npx expo run:android",
    "ios": "npx expo run:ios",
    "web": "npx expo start --web",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "expo": "~54.0.0",
    "expo-av": "~15.1.7",
    "expo-asset": "^12.0.12",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "babel-jest": "^30.2.0",
    "babel-preset-expo": "^54.0.10",
    "jest": "^30.2.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "utils/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
